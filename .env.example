PORT=3000
MACROPAGE_PORT=3001
MRFUELS_TRANSACT_PORT=3002

MACROPAGE_CONNECT_MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>/macropage-connect?retryWrites=true&w=majority

# mrfuels-transact app isn't built out yet — kept here for when it is
MRFUELS_TRANSACT_MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>/mrfuels?retryWrites=true&w=majority

# macropage app is a static site right now, no DB needed

JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=1d

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

ADMIN_EMAIL=admin@macropage.com
ADMIN_PASSWORD=change-me-123
ADMIN_NAME=Super Admin
