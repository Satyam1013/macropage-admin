PORT=3000

MACROPAGE_CONNECT_MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>/macropage-connect?retryWrites=true&w=majority

MRFUELS_TRANSACT_MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>/mrfuels?retryWrites=true&w=majority

JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=1d

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Single shared admin login — works for both /api/macropage-connect/* and /api/mr-fuels/* routes
ADMIN_EMAIL=admin@macropage.com
ADMIN_PASSWORD=change-me-123
ADMIN_NAME=Super Admin

# DigitalOcean Spaces — same bucket the real macropage-connect product uses
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=macropage-media
DO_SPACES_REGION=sfo3
